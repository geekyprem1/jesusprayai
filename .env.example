# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google login is configured in Supabase Dashboard (not env keys here):
# Authentication → Providers → Google → enable + Client ID / Secret
# Authentication → URL Configuration:
#   Site URL: https://YOUR_DOMAIN (or http://localhost:3000)
#   Redirect URLs: https://YOUR_DOMAIN/auth/callback
#                  http://localhost:3000/auth/callback
# Google Cloud Console → OAuth client → Authorized redirect URIs:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback

# ─── OpenRouter LLM ───────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# OPENROUTER_MODEL_CATEGORIZE=
# OPENROUTER_MODEL_VERSES=
# OPENROUTER_MODEL_DEVOTIONAL=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=PrayNote AI

# ─── Speech-to-text / voice prayer ────────────────────────
# auto = Whisper if OPENAI_API_KEY set, else browser speech in UI
# STT_PROVIDER=auto | openai_whisper | browser | none
STT_PROVIDER=auto
# Required for high-quality Whisper (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-...
# OPENAI_WHISPER_MODEL=whisper-1
# Optional language hint (e.g. en, hi) — leave empty for auto-detect
# STT_LANGUAGE=

# ─── Lemon Squeezy (Phase PAY only — leave empty) ─────────
# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_VARIANT_MONTHLY=
# LEMONSQUEEZY_VARIANT_ANNUAL=

# ─── Bible API (optional) ─────────────────────────────────
# BIBLE_API_KEY=
# API_BIBLE_ID_KJV=
# API_BIBLE_ID_NIV=
# API_BIBLE_ID_ESV=

# ─── Reminders / cron (Phase 4) ───────────────────────────
CRON_SECRET=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ─── Analytics (optional) ─────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_SENTRY_DSN=

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
